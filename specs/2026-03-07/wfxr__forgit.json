    {
      "name": "Interactive Git Selector",
      "purpose": "Display Git entities (files, branches, commits, etc.) in an fzf-powered interactive list with live previews for selection.",
      "primary_actions": [
        "Filter items using fzf search syntax",
        "Preview diffs or metadata before action",
        "Select item to stage, checkout, reset, or otherwise act upon"
      ]
    }
  ],
