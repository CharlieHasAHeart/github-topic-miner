          },
          {
            "name": "end_date",
            "type": "TEXT"
          },
          {
            "name": "is_round_trip",
            "type": "BOOLEAN"
          },
          {
            "name": "max_stops",
            "type": "TEXT"
          },
          {
            "name": "origin",
            "type": "TEXT"
          },
          {
