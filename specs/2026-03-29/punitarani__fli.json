{
  "schema_version": 3,
  "app": {
    "name": "fli",
    "one_liner": "A Python library providing programmatic, scraping-free access to Google Flights data via reverse-engineered API interaction, with CLI and MCP server interfaces."
  },
  "screens": [
    {
      "name": "Flight Search Interface",
      "purpose": "Enable users to configure and execute flight searches or cheapest-date queries through CLI or MCP integration.",
      "primary_actions": [
        "Configure cabin class, stops, airlines, and time windows",
        "Run `search_dates` across flexible date ranges",
        "Run `search_flights` with fixed travel dates"
      ]
    }
  ],
  "rust_commands": [
    {
      "name": "search_dates",
      "purpose": "Find the cheapest travel dates within a specified range, supporting round-trip duration and price-based sorting.",
      "async": true,
      "input": {
        "airlines": "json",
        "cabin_class": "string",
        "departure_window": "string",
        "destination": "string",
        "end_date": "string",
        "is_round_trip": "boolean",
        "payload": "json"
      },
      "output": {
        "ok": "boolean",
        "result": "json?"
      }
    },
    {
      "name": "search_flights",
      "purpose": "Search for flights on specific dates with detailed filtering options including cabin class, stops, airlines, and departure time windows.",
      "async": true,
      "input": {
        "airlines": "json",
        "cabin_class": "string",
        "departure_window": "string",
        "destination": "string",
        "end_date": "string",
        "is_round_trip": "boolean",
        "payload": "json"
      },
      "output": {
        "ok": "boolean",
        "result": "json?"
      }
    }
  ],
  "data_model": {
    "tables": [
      {
