  "mvp_plan": [
    "week 1: Build `search_flights` command with full parameter support",
    "week 1: Expose MCP server endpoint at /mcp/ with HTTP streaming",
    "week 1: Implement core reverse-engineered API client for Google Flights"
  ],
  "acceptance_tests": [
    "Given a 30-day date range and round-trip flag, `search_dates` returns cheapest outbound/return date pairs within constraints.",
    "Given valid origin, destination, and departure date, `search_flights` returns non-empty flight results sorted by CHEAPEST."
  ]
